# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Agent tooling state (kept out of the repo so local agent sessions don't
# leak between machines and developers).
.codegraph
.omo/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# CocoaPods (generated when running `pod install`; regenerated per machine).
**/Pods/
**/Podfile.lock

# Flutter's iOS plugin symlinks are regenerated by `flutter pub get` and
# shouldn't be committed. Each plugin's source still lives in pubspec deps.
ios/.symlinks/
ios/Flutter/Generated.xcconfig
ios/Flutter/flutter_export_environment.sh
macos/Flutter/GeneratedPluginRegistrant.swift
macos/Flutter/ephemeral/
linux/flutter/ephemeral/
windows/flutter/ephemeral/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Keystore / signing material. NEVER commit real release keys.
/android/app/*.jks
/android/app/*.keystore
/android/key.properties
/ios/Runner/GoogleService-Info.plist
*.p12
